#define BLYNK_PRINT Serial

#include <DHT.h>
#include <WiFi.h>
#include <BlynkSimpleEsp32.h>
#include <WiFiClient.h>

char auth[] = BLYNK_AUTH_TOKEN;
char ssid[] = "JioFiber-FnatF";
char pass[] = "P@iyali33";


DHT dht(22, DHT11);

BlynkTimer timer;

void SendSensor(){
  float temp = dht.readTemperature();
  float hum = dht.readHumidity();

  if(isnan(temp) || isnan(hum)){
    Serial.println("Failed to read!");
    return;
  }

  Blynk.virtualWrite(V0, temp);
  Blynk.virtualWrite(V1, hum);

  Serial.print("Temperature: ");
  Serial.print(temp);
  Serial.println(" C ");

  Serial.print("Humidity: ");
  Serial.print(hum);
  Serial.println(" % ");

}
void setup() {
  Serial.begin(115200);
  delay(500);

  Serial.println("1. Setup started");

  dht.begin();
  Serial.println("2. DHT initialized");

  Serial.println("3. Connecting to Blynk...");
  Blynk.begin(BLYNK_AUTH_TOKEN, ssid, pass);

  Serial.println("4. Connected to Blynk!");

  timer.setInterval(500L, SendSensor);

  Serial.println("5. Timer configured");
}

void loop() {
  // put your main code here, to run repeatedly:
  Blynk.run();
  timer.run();
}
